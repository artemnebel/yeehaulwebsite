# Copy this file to ".env" for local testing. On Render, set these same
# keys under the service's "Environment" tab instead (never commit real values).

# The Gmail account that will SEND the quote emails.
EMAIL_USER=yeehauljunkremoval26@gmail.com

# A Gmail APP PASSWORD (16 characters, no spaces) — NOT your normal password.
# Create one at https://myaccount.google.com/apppasswords (2-Step Verification must be on).
EMAIL_PASS=your16charapppassword

# Where the quotes get delivered (can be the same as EMAIL_USER).
TO_EMAIL=yeehauljunkremoval26@gmail.com

# Your website's origin, to restrict who can POST to this server.
# Leave blank while testing; set it once you have a real domain, e.g.
# ALLOWED_ORIGIN=https://yeehauljunkremoval.com
ALLOWED_ORIGIN=
