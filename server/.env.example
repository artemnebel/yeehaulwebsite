# Copy this file to ".env" for local testing. On Render, set these same
# keys under the service's "Environment" tab instead (never commit real values).

# Your Resend API key. Create one at https://resend.com/api-keys
# (starts with "re_"). Give it "Sending access".
RESEND_API_KEY=re_yourapikeyhere

# The "From" address shown on the quote emails. It must be on a domain you've
# verified in Resend (https://resend.com/domains). Until you verify your own
# domain, use Resend's shared sender below — it can ONLY deliver to the email
# address you signed up to Resend with.
FROM_EMAIL=Yeehaul Website <onboarding@resend.dev>

# Where the quotes get delivered. While using onboarding@resend.dev above, this
# MUST be the email you registered your Resend account with.
TO_EMAIL=yeehauljunkremoval26@gmail.com

# Your website's origin, to restrict who can POST to this server.
# Leave blank while testing; set it once you have a real domain, e.g.
# ALLOWED_ORIGIN=https://yeehauljunkremoval.com
ALLOWED_ORIGIN=
